# =====================================================================
# SECRETS TEMPLATE  ->  copy to: config/secrets.local  (git-ignored)
#
#   cp config/secrets.local.example config/secrets.local
#
# Fill in your own DEVELOPMENT values. See README.md Section 21
# ("Owner Setup and Provisioning Guide") for how to obtain each one.
# Every service below has a free tier sufficient for the MVP.
# NEVER commit config/secrets.local.
# =====================================================================

# --- Google OAuth  (Google Cloud Console) -----------------------------
GOOGLE_OAUTH_CLIENT_ID=
# (Google also issues a Client Secret, but this app's token-verify flow never uses it.)

# --- Turso  (dev database: turso db show --url / db tokens create) -----
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Vercel Blob  (Storage > Blob store) ------------------------------
BLOB_READ_WRITE_TOKEN=

# --- Gmail SMTP  (order-reminder email; no domain to buy) -------------
# Your Gmail address, plus an App Password for it (Google Account >
# Security > 2-Step Verification > App passwords). ~500 emails/day free.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Web Push  (run: npx web-push generate-vapid-keys) ----------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- App secrets  (run: openssl rand -base64 32) ----------------------
SESSION_SECRET=
CRON_SECRET=
