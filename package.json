{
  "name": "makankira",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MakanKira API layer and tooling (TypeScript serverless functions + build scripts).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "config": "node scripts/load-config.mjs",
    "migrate": "tsx scripts/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"api/_lib/**/*.test.ts\"",
    "dev": "vercel dev",
    "build:web": "flutter build web --release --dart-define-from-file=config/frontend.local.json"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@vercel/blob": "^2.0.0",
    "exceljs": "^4.4.0",
    "jose": "^6.2.3",
    "nanoid": "^5.1.16",
    "nodemailer": "^9.0.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/web-push": "^3.6.4",
    "@vercel/node": "^5.8.22",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "yaml": "^2.9.0"
  }
}
